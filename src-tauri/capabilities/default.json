{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities",
  "windows": ["main"],
  "permissions": [
    "fs:default",
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$APPLOG/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$TEMP/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$APPLOG/**" },
        { "path": "$APPCONFIG/**" }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "$APPLOG/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$TEMP/**" }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "opencode", "cmd": "opencode", "args": true }
      ]
    },
    "dialog:allow-open",
    "core:event:default"
  ]
}
